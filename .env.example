# ============================================================
# AI Property Advisor - Environment Configuration
# ============================================================
# Copy this file to .env and adjust values:
#   copy .env.example .env
#
# Note: He thong se tu dong seed database SQLite voi du lieu mau
#     (6 landlord scenarios) neu database trong.

# --- Database ---
DATABASE_URL=sqlite:///database/test_data.db

# --- Google Gemini AI ---
# Get free API key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Server ---
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# --- Logging ---
LOG_LEVEL=INFO
ENVIRONMENT=development

